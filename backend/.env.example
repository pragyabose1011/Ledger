# ── Required ──────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-to-a-random-secret-in-production

# MySQL — matches docker-compose.yml defaults
DATABASE_URL=mysql+pymysql://ledger:ledgerpass@localhost:3306/ledger

# ── AI — pick one ─────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# Or use a local Ollama instance instead of OpenAI:
# USE_OLLAMA=true
# OLLAMA_MODEL=llama3.2
# OLLAMA_BASE_URL=http://localhost:11434

# ── Frontend URL ──────────────────────────────────────────────────────
# Controls OAuth redirect URIs and links in notification emails.
# In Docker: http://localhost
# In production: https://your-domain.com
FRONTEND_URL=http://localhost

# Additional CORS origins (comma-separated, optional)
# EXTRA_CORS_ORIGINS=https://your-domain.com

# ── OAuth providers (all optional) ───────────────────────────────────
# Google — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Zoom — https://marketplace.zoom.us/develop/create
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_ACCOUNT_ID=

# Microsoft — https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Slack — https://api.slack.com/apps
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# ── Email notifications (optional) ───────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM_NAME=Ledger

# ── Stripe billing (optional) ─────────────────────────────────────────
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...
